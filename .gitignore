# Build output
build/
build-*/
out/
cmake-build-*/

# IDE state
.vs/
.vscode/
*.user
*.user.*
CMakeUserPresets.json
CMakeCache.txt
CMakeFiles/

# Qt Creator
*.pro.user*
*.qmlproject.user*

# MSVC + linker
*.obj
*.exp
*.lib
*.pdb
*.ilk
*.exe
*.dll

# Tracked WDSP / FFTW / RNNoise / SpecBleach binaries -- these are
# load-bearing GPL v3+ dependencies that ship WITH the source so
# the repo is build-from-scratch reproducible.  Per FEATURES.md §0
# the locked architecture row links WDSP directly into Lyra; these
# are NOT build output (they originate in lyra/dsp/_native/ in the
# Python tree, bundled identically).  Negate the *.dll rule above
# for this single directory only.
!_native/
!_native/*.dll

# OS noise
Thumbs.db
.DS_Store

# Local source-backup zips (not part of the repo)
_backups/

# Local operator-machine build helpers + logs (not part of the repo)
_b.bat
_b*.bat
# All build/test output-capture logs (operator-machine, transient).
*.log
*.log.err

# Python tooling bytecode cache
__pycache__/
*.pyc

# Release artifacts — the installer is attached to the GitHub Release,
# never committed (see CMakeLists OutputDir / installer/lyra.iss).
dist/
